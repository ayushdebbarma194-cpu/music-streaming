# ArchiveTune Backend Service - Environment Variables
# Copy this file to .env and fill in your own keys/tokens.

# ─── YouTube Music (InnerTube) ───────────────────────────────────
# No API key needed for InnerTube — it uses the public internal API.
# Optionally, provide ytmusicapi auth headers file path:
# YTMUSIC_AUTH_FILE=browser.json

# ─── Last.fm Scrobbling ──────────────────────────────────────────
# Register at https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_USERNAME=
LASTFM_PASSWORD=

# ─── ListenBrainz Scrobbling ────────────────────────────────────
# Get your token at https://listenbrainz.org/settings/
LISTENBRAINZ_TOKEN=

# ─── AI Providers (supply one or more) ───────────────────────────
# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Google Cloud Translation (optional) ─────────────────────────
# If not set, falls back to googletrans (free, unofficial)
GCP_TRANSLATION_API_KEY=

# ─── Downloads ───────────────────────────────────────────────────
# Directory for offline downloaded tracks
DOWNLOAD_DIR=./downloads

# ─── Server ──────────────────────────────────────────────────────
# Host and port (localhost-only by default for security)
HOST=127.0.0.1
PORT=8000
